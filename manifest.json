{
  "manifest_version": 3,
  "name": "Quick Notes",
  "version": "2.0.0",
  "description": "快速笔记 - 支持搜索、深色模式、导入导出、笔记置顶",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
